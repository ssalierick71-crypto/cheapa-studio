{
  "builds": [
    { "src": "*.php", "use": "vercel-php@0.7.4" },
    { "src": "admin/*.php", "use": "vercel-php@0.7.4" },
    { "src": "assets/**", "use": "@vercel/static" },
    { "src": "robots.txt", "use": "@vercel/static" },
    { "src": "sitemap.xml", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/", "dest": "/index.php" },
    { "handle": "filesystem" }
  ]
}
