# ============================================================
#  Cheapa Studio — environment configuration
#  Copy to ".env" for local overrides (git-ignored). On Vercel,
#  set these in Project → Settings → Environment Variables instead.
# ============================================================

# ── Database ────────────────────────────────────────────────
# LOCAL (XAMPP): leave as-is, the defaults already work (mysql/root/no pass).
# SUPABASE: switch DB_DRIVER to pgsql and fill in the connection details
#           from Supabase → Project Settings → Database → Connection string.
#           Use the *Connection pooler* host (port 6543, transaction mode)
#           for serverless/Vercel — db.php is already pgbouncer-safe.
DB_DRIVER=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=cheapa_db
DB_USER=root
DB_PASS=
# Postgres only: SSL mode (Supabase requires SSL)
DB_SSLMODE=require

# ── File storage ────────────────────────────────────────────
# local    = save uploads to /uploads on disk (XAMPP).
# supabase = save uploads to a Supabase Storage bucket (required on Vercel,
#            whose filesystem is read-only).
STORAGE_DRIVER=local
SUPABASE_URL=
SUPABASE_BUCKET=cheapa
# Service-role key (Storage write access). KEEP SECRET — server-side only.
SUPABASE_SERVICE_KEY=

# ── Sessions ────────────────────────────────────────────────
# file = PHP file sessions (XAMPP).
# db   = store sessions in the `sessions` table (required on Vercel/serverless).
SESSION_DRIVER=file
